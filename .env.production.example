# ─────────────────────────────────────────────────────────────────────────────
# govManage — PRODUCTION Environment Variables Template
# 
# IMPORTANT:
# 1. Do NOT commit this file with real secrets.
# 2. In production (Heroku, Render, AWS, etc.), set these via your platform's 
#    Secrets / Config Vars UI rather than a `.env` file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server & Security ─────────────────────────────────────────────────────────
# MUST be 0 in production
FLASK_DEBUG=0
PORT=5000

# MUST be set to your deployed frontend's EXACT origin (no trailing slash)
# Example: https://govmanage.yourdomain.com
CORS_ORIGINS=https://<your-production-frontend-domain>

# ── Database ──────────────────────────────────────────────────────────────────
# Production MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<production-user>:<production-password>@<cluster>.mongodb.net/?appName=govmanage
MONGO_DB_NAME=govmanage

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Use production-level API keys with appropriate billing limits
GROQ_API_KEY=<your-production-groq-key>
GROQ_MODEL=llama-3.3-70b-versatile

# ── Web Intelligence (optional) ──────────────────────────────────────────────
INTERNET_INTELLIGENCE_ENABLED=true
TAVILY_API_KEY=<your-production-tavily-key>
FIRECRAWL_API_KEY=<your-production-firecrawl-key>

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Used for sending out Weekly Reports and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-production-email>
SMTP_PASSWORD=<your-production-app-password>
SMTP_FROM=govManage Reports <no-reply@yourdomain.com>
SMTP_USE_TLS=true
# Comma-separated list of admins who will receive the weekly PDF report
EMAIL_RECIPIENTS=admin1@yourdomain.com,admin2@yourdomain.com

# ── Email Schedule (optional) ─────────────────────────────────────────────────
EMAIL_WEEKLY_DAY=monday
EMAIL_WEEKLY_TIME=08:00


# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION NOTE:
# The variables below belong in your FRONTEND build environment (e.g., Vercel, Netlify).
# They do NOT belong in the backend Python server environment.
# ─────────────────────────────────────────────────────────────────────────────
# VITE_API_URL=https://<your-production-backend-domain>/api
