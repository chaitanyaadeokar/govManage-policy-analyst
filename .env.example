# ─────────────────────────────────────────────────────────────────────────────
# govManage — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGO_DB_NAME=govmanage

# ── Web Intelligence (optional) ──────────────────────────────────────────────
INTERNET_INTELLIGENCE_ENABLED=false
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=govManage Reports <your@email.com>
SMTP_USE_TLS=true
EMAIL_RECIPIENTS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# Set to 1 ONLY for local development — NEVER in production
FLASK_DEBUG=0

# Comma-separated list of allowed frontend origins (CORS)
# Example production: CORS_ORIGINS=https://govmanage.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Email Schedule (optional) ─────────────────────────────────────────────────
EMAIL_WEEKLY_DAY=monday
EMAIL_WEEKLY_TIME=08:00
