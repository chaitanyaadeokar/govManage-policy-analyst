# govManage Frontend — Environment Variables Template
# Copy to .env.local for local development or set in your hosting platform

# Backend API URL
# By default, the app uses '/api' which works perfectly when served by the Flask backend
# or via the Vite proxy. You only need to set this if hosting the frontend on a
# completely separate domain from the backend.
# VITE_API_URL=https://govmanage-api.yourdomain.com/api
